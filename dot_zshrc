# 1. p10k instant prompt (must be first)
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# 2. oh-my-zsh config
ZSH="$HOME/.oh-my-zsh"
ZSH_CUSTOM="$XDG_CONFIG_HOME/zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"
ZSH_AUTOSUGGEST_MANUAL_REBIND=1
ZOXIDE_CMD_OVERRIDE=cd
DISABLE_AUTO_UPDATE=true
DISABLE_MAGIC_FUNCTIONS=true
DISABLE_LS_COLORS=true

# 3. tool config
EZA_CONFIG_DIR="$XDG_CONFIG_HOME/eza"
export NVM_COMPLETION=true
export NVM_DIR="$HOME/.nvm"
export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac
export PATH="$HOME/.local/bin:$PATH"

# 4. plugins
plugins=(brew eza fzf git npm pm2 yarn zoxide zsh-autosuggestions zsh-syntax-highlighting)
zstyle ':omz:*' aliases no
zstyle ':omz:plugins:eza' aliases yes
zstyle ':omz:plugins:eza' 'icons' yes
zstyle ':omz:plugins:git' aliases yes
zstyle ':omz:plugins:pm2' aliases yes
zstyle ':omz:plugins:yarn' aliases yes
bindkey -e

# 5. source oh-my-zsh
source $(brew --prefix asdf)/libexec/asdf.sh
source "$ZSH/oh-my-zsh.sh"

# 6. NVM
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# 7. theme + prompt (after oh-my-zsh so zstyle completion works)
source "$ZSH_CUSTOM/theme/tokyonight-moon.zsh"
source "$ZSH_CUSTOM/p10k.zsh"
